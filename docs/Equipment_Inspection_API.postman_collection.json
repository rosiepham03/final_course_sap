{
  "info": {
    "_postman_id": "inspection-service-cap-java-collection",
    "name": "Inspection Service - SAP CAP Java",
    "description": "Postman collection để test InspectionService (OData V4) của dự án Equipment Inspection\nBase URL: http://localhost:8080/odata/v4/InspectionService",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Search Inspections",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/searchInspections(params={ \"equipmentId\": \"\", \"equipmentName\": \"\", \"inspectorId\": \"\", \"status\": \"\", \"inspectionDateFrom\": \"\", \"inspectionDateTo\": \"\" })",
          "host": ["{{baseUrl}}"],
          "path": ["searchInspections"],
          "query": [
            {
              "key": "params",
              "value": "{ \"equipmentId\": \"\", \"equipmentName\": \"\", \"inspectorId\": \"\", \"status\": \"\", \"inspectionDateFrom\": \"2025-01-01\", \"inspectionDateTo\": \"2026-03-28\" }"
            }
          ]
        },
        "description": "Tìm kiếm inspections với nhiều filter"
      }
    },
    {
      "name": "2. Get Inspection Details",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/getInspectionDetails(inspectionId='{{inspectionId}}')",
          "host": ["{{baseUrl}}"],
          "path": ["getInspectionDetails"],
          "query": []
        },
        "description": "Lấy chi tiết một inspection"
      }
    },
    {
      "name": "3. Generate Report (PDF)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"inspectionId\": \"{{inspectionId}}\",\n  \"additionalComments\": \"Thiết bị hoạt động bình thường, không phát hiện vấn đề an toàn lớn.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/generateReport",
          "host": ["{{baseUrl}}"],
          "path": ["generateReport"]
        },
        "description": "Tạo báo cáo PDF (trả về binary PDF - dùng Send and Download)"
      }
    },
    {
      "name": "4. Export Report PDF",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/exportReportPdf(reportId='{{reportId}}')",
          "host": ["{{baseUrl}}"],
          "path": ["exportReportPdf"]
        },
        "description": "Export PDF đã tạo (trả về binary)"
      }
    },
    {
      "name": "5. Add Comment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"inspectionId\": \"{{inspectionId}}\",\n  \"commentText\": \"Cần kiểm tra lại van an toàn trong lần bảo dưỡng tới.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/addComment",
          "host": ["{{baseUrl}}"],
          "path": ["addComment"]
        }
      }
    },
    {
      "name": "6. Approve Inspection",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"inspectionId\": \"{{inspectionId}}\",\n  \"additionalComments\": \"Đã kiểm tra đầy đủ\",\n  \"approvalNote\": \"Phê duyệt bởi Trưởng phòng Kỹ thuật - Ngày 28/03/2026\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/approveInspection",
          "host": ["{{baseUrl}}"],
          "path": ["approveInspection"]
        }
      }
    },
    {
      "name": "CRUD - Get All Inspections",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/Inspection?$expand=equipment,inspector&$top=20",
          "host": ["{{baseUrl}}"],
          "path": ["Inspection"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/odata/v4/InspectionService",
      "type": "string"
    },
    {
      "key": "inspectionId",
      "value": "paste-inspection-uuid-here",
      "type": "string"
    },
    {
      "key": "reportId",
      "value": "paste-report-uuid-here",
      "type": "string"
    }
  ]
}